<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fq.modules.sys.menu.mapper.SysMenuMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.fq.modules.sys.menu.entity.SysMenu">
        <id column="id" property="id" />
        <result column="parent_id" property="parentId" />
        <result column="menu_type" property="menuType" />
        <result column="permission_tag" property="permissionTag" />
        <result column="path" property="path" />
        <result column="component" property="component" />
        <result column="redirect" property="redirect" />
        <result column="name" property="name" />
        <result column="meta_title" property="metaTitle" />
        <result column="meta_icon" property="metaIcon" />
        <result column="meta_active_menu" property="metaActiveMenu" />
        <result column="meta_no_cache" property="metaNoCache" />
        <result column="hidden" property="hidden" />
        <result column="sort" property="sort" />
        <result column="state" property="state" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />
        <result column="create_by" property="createBy" />
        <result column="update_by" property="updateBy" />
        <result column="data_flag" property="dataFlag" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        `id`,`parent_id`,`menu_type`,`permission_tag`,`path`,`component`,`redirect`,`name`,`meta_title`,`meta_icon`,`meta_active_menu`,`meta_no_cache`,`hidden`,`sort`,`create_time`,`update_time`,`create_by`,`update_by`,`data_flag`
    </sql>



    <select id="findUserMenu" resultType="java.lang.Long">
        SELECT DISTINCT rm.menu_id
        FROM sys_role_menu rm
                 LEFT JOIN sys_user_role ro ON ro.role_id = rm.role_id
        WHERE ro.user_id=#{userId}
    </select>

    <select id="findAllMenu" resultMap="BaseResultMap">
        SELECT mu.* FROM sys_menu mu ORDER BY mu.sort ASC
    </select>

    <select id="paging" resultType="com.fq.modules.sys.menu.dto.SysMenuDTO">
        SELECT mu.* FROM sys_menu mu
        <where>
            <if test="query != null">
                <if test="query.metaTitle != null and query.metaTitle != ''">
                    AND mu.meta_title LIKE concat('%',#{query.metaTitle},'%')
                </if>
                <if test="query.menuType != null">
                    AND mu.menu_type = #{query.menuType}
                </if>
                <if test="query.id != null">
                    AND mu.id = #{query.id}
                </if>
                <if test="query.sort != null">
                    AND mu.sort = #{query.sort}
                </if>
                <if test="query.path != null and query.path != ''">
                    AND mu.path = #{query.path}
                </if>
                <if test="query.startTime != null and query.startTime != '' and query.endTime != null and query.endTime != ''">
                    AND mu.create_time BETWEEN #{query.startTime} AND #{query.endTime}
                </if>
                <if test="query.state != null">
                    AND mu.state = #{query.state}
                </if>
            </if>
        </where>
    </select>
</mapper>