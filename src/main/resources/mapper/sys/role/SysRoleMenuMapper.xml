<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fq.modules.sys.role.mapper.SysRoleMenuMapper">
    <select id="findRolePerms" resultType="java.lang.String">
        SELECT sm.permission_tag
        FROM sys_role_menu srm
                 LEFT JOIN sys_menu sm on sm.id = srm.menu_id
        WHERE srm.role_id = #{roleId}
    </select>

    <select id="findRoleIdsByMenuId" resultType="java.lang.String">
        SELECT role_id
        FROM sys_role_menu
        WHERE menu_id = #{menuId}
    </select>

    <delete id="deleteByMenuId">
        DELETE
        FROM sys_role_menu
        WHERE menu_id = #{menuId}
    </delete>
</mapper>