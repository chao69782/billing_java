<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fq.modules.category.mapper.CategoryMapper">

    <select id="listByCategoryType" resultType="com.fq.modules.category.entity.Category">
        SELECT id, category_name, category_icon FROM category WHERE category_type = #{categoryType}
    </select>
</mapper>
